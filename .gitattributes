# Auto-detect text files and perform LF normalization
* text=auto

# Ensure Python files are treated as text
*.py text eol=lf

# Explicitly mark data files as binary to prevent corruption
*.npy binary
*.npz binary
*.pt binary
*.h5 binary
*.keras binary
*.parquet binary

# Ensure documentation files use LF
*.md text eol=lf
*.txt text eol=lf

# Configure git-lfs for large binary files
*.pt filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.keras filter=lfs diff=lfs merge=lfs -text
*.npy filter=lfs diff=lfs merge=lfs -text
